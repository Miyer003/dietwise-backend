# ============================================
# 膳智 DietWise - 生产环境配置
# ============================================

# 运行模式
NODE_ENV=production

# Server
PORT=3000
# 生产环境绑定 0.0.0.0 接受所有请求
HOST=0.0.0.0

# Database (生产环境请使用强密码)
DB_HOST=your-db-host.com
DB_PORT=5432
DB_USERNAME=dietwise
DB_PASSWORD=your-strong-password
DB_DATABASE=dietwise
DB_SYNC=false  # 生产环境关闭自动同步

# Redis
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT (生产环境请生成强密钥)
JWT_SECRET=your-production-jwt-secret-min-32-characters
JWT_ACCESS_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# MinIO (生产环境使用云服务或独立服务器)
# 方式1: 自有 MinIO 服务器
MINIO_ENDPOINT=minio.your-domain.com
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=dietwise

# 公网访问端点（手机/外部客户端用，如果与 MINIO_ENDPOINT 不同则填写）
# 例如：使用 CDN 或内网 MinIO 但对外提供不同域名时
# MINIO_PUBLIC_ENDPOINT=minio-cdn.your-domain.com

# 方式2: 阿里云 OSS / 腾讯云 COS / AWS S3
# 需要额外安装 aws-sdk 并修改 minio.service.ts

# AI Services (生产环境使用正式 API Key)
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_VL_MODEL=qwen-vl-plus
DASHSCOPE_TEXT_MODEL=qwen-turbo
DASHSCOPE_AUDIO_MODEL=qwen-omni-turbo
DASHSCOPE_TTS_MODEL=qwen3-tts-vd-2026-01-26

MOONSHOT_API_KEY=your-moonshot-api-key
MOONSHOT_MODEL=kimi-k2-turbo-preview
